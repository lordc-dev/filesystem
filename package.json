{
  "name": "filesystem-pro",
  "version": "1.0.0",
  "description": "Production-grade MCP filesystem server \u2014 50 tools, ripgrep search (~10x faster), tree-sitter semantic analysis (18 languages), full undo stack, and enterprise security hardening \u2014 purpose-built for LMs and AI agents.",
  "license": "MIT",
  "author": "Alberto Castro Otero",
  "homepage": "https://github.com/lordc-dev/filesystem-pro",
  "bugs": "https://github.com/lordc-dev/filesystem-pro/issues",
  "type": "module",
  "bin": {
    "filesystem-pro": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/index.js && shx mkdir -p dist/grammars && node scripts/copy-grammars.mjs",
    "build-strict": "tsc && shx chmod +x dist/index.js",
    "clean": "shx rm -rf dist",
    "prepare": "npm run build",
    "postinstall": "npm run build",
    "watch": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit --skipLibCheck false",
    "eslint": "eslint src/",
    "eslint:fix": "eslint src/ --fix",
    "bench": "vitest run tests/performance-bench.test.ts",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^5.0.0",
    "diff": "^8.0.4",
    "picomatch": "^4.0.4",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.24.0",
    "web-tree-sitter": "0.26.9",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@swc/cli": "^0.7.9",
    "@swc/core": "^1.15.7",
    "@types/node": "^25.9.1",
    "@types/picomatch": "^4.0.3",
    "@vitest/coverage-v8": "^4.1.7",
    "esbuild": "^0.27.7",
    "eslint": "^10.4.1",
    "fast-check": "^4.8.0",
    "globals": "^17.6.0",
    "shx": "^0.4.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "tree-sitter-wasms": "^0.1.13",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "onlyBuiltDependencies": [
    "tree-sitter-kotlin",
    "tree-sitter-javascript",
    "tree-sitter-python",
    "tree-sitter-typescript",
    "esbuild",
    "@swc/core"
  ]
}
